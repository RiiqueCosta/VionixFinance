rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Pillar 0: Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Transactions
    match /transactions/{id} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid
          && data.amount is number
          && data.type in ['receita', 'fixa', 'variavel']
          && data.date is string
          && (data.description is string && data.description.size() <= 500)
          && (data.category is string && data.category.size() <= 100)
          && data.keys().hasAll(['userId', 'amount', 'type', 'description', 'category', 'date']);
      }

      // Secure list queries - evaluate based on resource data
      allow list: if isSignedIn() && (existing() == null || existing().userId == request.auth.uid);
      allow get: if isSignedIn() && (existing() == null || existing().userId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && isValidTransaction(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid 
        && isValidTransaction(incoming())
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Goals
    match /goals/{id} {
      function isValidGoal(data) {
        return data.userId == request.auth.uid
          && data.title is string
          && data.targetAmount is number
          && data.currentAmount is number
          && data.keys().hasAll(['userId', 'title', 'targetAmount', 'currentAmount']);
      }

      allow list: if isSignedIn() && (existing() == null || existing().userId == request.auth.uid);
      allow get: if isSignedIn() && (existing() == null || existing().userId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && isValidGoal(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid 
        && isValidGoal(incoming())
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
