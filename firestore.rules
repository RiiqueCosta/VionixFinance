rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Rule for transactions: users can only read/write their own data
    match /transactions/{id} {
      allow read, write: if isSignedIn() 
        && (resource == null || resource.data.userId == request.auth.uid)
        && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Rule for goals: users can only read/write their own data
    match /goals/{id} {
      allow read, write: if isSignedIn() 
        && (resource == null || resource.data.userId == request.auth.uid)
        && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Rule for user-specific data (settings, etc)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Test connection path
    match /test/connection {
      allow read: if true;
    }
  }
}
