{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "type": {
          "enum": [
            "receita",
            "fixa",
            "variavel"
          ]
        },
        "description": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "category": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "note": {
          "type": "string"
        },
        "recurring": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "type",
        "description",
        "amount",
        "category",
        "date",
        "createdAt",
        "updatedAt"
      ]
    },
    "FinancialGoal": {
      "title": "FinancialGoal",
      "description": "Financial goal for the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "targetAmount": {
          "type": "number"
        },
        "currentAmount": {
          "type": "number"
        },
        "deadline": {
          "type": "string",
          "format": "date-time"
        },
        "category": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "title",
        "targetAmount",
        "currentAmount",
        "category",
        "createdAt",
        "updatedAt"
      ]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User specific settings and categories",
      "type": "object",
      "properties": {
        "categories": {
          "type": "object",
          "properties": {
            "receita": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "fixa": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "variavel": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "categories",
        "updatedAt"
      ]
    },
    "CreditCard": {
      "title": "CreditCard",
      "description": "Credit card account",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "limitTotal": { "type": "number" },
        "closingDay": { "type": "number" },
        "dueDay": { "type": "number" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "limitTotal", "closingDay", "dueDay", "color", "createdAt", "updatedAt"]
    },
    "CreditTransaction": {
      "title": "CreditTransaction",
      "description": "Transaction made using a credit card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "installmentsTotal": { "type": "number" },
        "installmentNumber": { "type": "number" },
        "groupId": { "type": "string" },
        "invoiceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "cardId", "description", "amount", "category", "date", "installmentsTotal", "installmentNumber", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Credit card monthly invoice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "status": { "enum": ["aberta", "fechada", "paga"] },
        "totalAmount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "cardId", "month", "year", "status", "totalAmount", "updatedAt"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions collection"
    },
    "/goals/{goalId}": {
      "schema": "FinancialGoal",
      "description": "Financial goals collection"
    },
    "/users/{userId}/settings/data": {
      "schema": "UserSettings",
      "description": "User specific settings"
    },
    "/creditCards/{cardId}": {
      "schema": "CreditCard",
      "description": "Credit cards collection"
    },
    "/creditTransactions/{txId}": {
      "schema": "CreditTransaction",
      "description": "Credit card transactions collection"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices collection"
    }
  }
}
