rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users & Settings
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /settings/{docId} {
        allow get, list, write: if isOwner(userId);
      }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Transactions
    match /transactions/{id} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid
          && (data.amount is number || data.amount is int)
          && data.type in ['receita', 'fixa', 'variavel', 'investimento']
          && data.date is string
          && data.keys().hasAll(['userId', 'amount', 'type', 'description', 'category', 'date']);
      }

      // Pillar 8: Secure List Queries
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Pillar 3: Path Variable Hardening
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
      
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && (request.resource == null || (isValidTransaction(request.resource.data) && request.resource.data.userId == resource.data.userId));
        
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 3. Goals
    match /goals/{id} {
      function isValidGoal(data) {
        return data.userId == request.auth.uid
          && (data.targetAmount is number || data.targetAmount is int)
          && data.keys().hasAll(['userId', 'title', 'targetAmount', 'currentAmount']);
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidGoal(request.resource.data);
      
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && (request.resource == null || (isValidGoal(request.resource.data) && request.resource.data.userId == resource.data.userId));
        
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 4. Test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
